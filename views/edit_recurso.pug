extends layout

block content
  .w3-container.w3-margin
    .w3-card-4
      header.w3-container.w3-blue-grey
        h2 Editar Metadados do Recurso
      form.w3-container.w3-padding(method="POST")
        label.w3-text-blue-grey: b Título
        input.w3-input.w3-border(type="text" name="titulo" value=r.titulo required)
        
        label.w3-text-blue-grey: b Tipo
        select.w3-select.w3-border(name="tipo")
          option(value=r.tipo selected)= r.tipo
          option(value="Trabalho") Trabalho
          option(value="Exame") Exame
          option(value="Aula") Aula
          option(value="Outro") Outro

        label.w3-text-blue-grey: b Visibilidade
        select.w3-select.w3-border(name="visibilidade")
          option(value="publico" selected=(r.visibilidade=="publico")) Público
          option(value="privado" selected=(r.visibilidade=="privado")) Privado

        br
        button.w3-btn.w3-blue-grey.w3-round(type="submit") Atualizar
        a.w3-btn.w3-red.w3-round.w3-margin-left(href="/recursos/" + r._id) Cancelar