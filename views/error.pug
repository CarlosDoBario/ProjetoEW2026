extends layout

block content
  .w3-container.w3-margin-top.w3-center
    .w3-card-4.w3-white(style="max-width: 800px; margin: auto; padding: 40px;")
      //- Seleção de ícone e título baseada no status do erro
      if error.status == 404
        h1.w3-text-orange.w3-jumbo 404
        h2.w3-text-dark-grey Página Não Encontrada
        p.w3-text-grey O conteúdo que procura não existe ou foi movido.
      else if error.status == 403
        h1.w3-text-red.w3-jumbo 🚫
        h2.w3-text-dark-grey Acesso Negado
        p.w3-text-grey Ups! Parece que não tens as chaves certas para entrar aqui.
      else
        h1.w3-text-red.w3-jumbo ⚠️
        h2.w3-text-dark-grey Erro no Servidor
        p.w3-text-grey= message

      hr.w3-border-light-grey

      //- Relatório de erros (Stack Trace) visível apenas em desenvolvimento
      if error.stack
        .w3-left-align.w3-light-grey.w3-padding.w3-round.w3-small.w3-margin-bottom(style="overflow-x: auto;")
          pre= error.stack

      .w3-margin-top
        a.w3-button.w3-teal.w3-round-large(href="/") 🏠 Voltar ao Início
        button.w3-button.w3-border.w3-round-large.w3-margin-left(onclick="history.back()") ⬅️ Voltar atrás