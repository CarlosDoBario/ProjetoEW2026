extends layout

block content
  .w3-container.w3-margin-top
    .w3-card-4.w3-display-middle(style="width:50%")
      header.w3-container.w3-teal
        h2 Registo de Utilizador
      form.w3-container.w3-padding-16(action="/registo" method="POST")
        label Nome Completo
        input.w3-input.w3-border.w3-margin-bottom(type="text" name="nome" required)
        
        label Email
        input.w3-input.w3-border.w3-margin-bottom(type="email" name="email" required)
        
        label Password
        input.w3-input.w3-border.w3-margin-bottom(type="password" name="password" required)
        
        label Filiação
        input.w3-input.w3-border.w3-margin-bottom(type="text" name="filiacao")
        
        label Nível de Acesso
        select.w3-select.w3-border.w3-margin-bottom(name="nivel")
            option(value="consumidor" selected) Consumidor
            option(value="produtor") Produtor
            option(value="administrador") Administrador
            
        button.w3-button.w3-teal.w3-block.w3-margin-top.w3-round(type="submit") Criar Conta