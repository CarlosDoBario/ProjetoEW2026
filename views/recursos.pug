extends layout

block content
  .w3-container.w3-margin-top
    .w3-card-4
      header.w3-container.w3-teal
        h2 📚 Recursos Disponíveis
        p Consulta e descarrega os materiais partilhados.
      
      .w3-container.w3-padding-16
        //- Formulário de Filtros e Ordenação Avançada
        form(method="GET" action="/recursos" class="w3-margin-bottom")
          .w3-row-padding
            .w3-col.s4
              label Pesquisar:
              input.w3-input.w3-border.w3-round(
                type="text" 
                name="search" 
                placeholder="Título..." 
                value=(filtros ? filtros.search : '')
              )
            .w3-col.s3
              label Tipo:
              select.w3-select.w3-border(name="tipo")
                option(value="") Todos
                - var tipos = ['Teste', 'Exame', 'Relatório', 'Trabalho']
                each t in tipos
                  option(value=t selected=(filtros && filtros.tipo == t))= t
            .w3-col.s3
              label Ordenar por:
              select.w3-select.w3-border(name="sort")
                option(value="data" selected=(filtros && filtros.sort == "data")) Data (Recente)
                option(value="downloads" selected=(filtros && filtros.sort == "downloads")) Downloads
                option(value="titulo" selected=(filtros && filtros.sort == "titulo")) Título (A-Z)
            .w3-col.s2.w3-margin-top
              button.w3-button.w3-teal.w3-block.w3-round(type="submit") 🔍 Filtrar
            
        if lista && lista.length > 0
          table.w3-table-all.w3-hoverable
            thead
              tr.w3-dark-grey
                th Título
                th Produtor
                th Visibilidade
                th Data de Registo
            tbody
              each r in lista
                tr
                  td
                    a(href="/recursos/" + r._id).w3-text-teal.w3-hover-text-amber **#{r.titulo}**
                  td= r.produtor
                  td
                    span.w3-tag.w3-round(class=(r.visibilidade === 'publico' ? 'w3-green' : 'w3-orange'))= r.visibilidade
                  td= r.dataRegisto ? r.dataRegisto.substring(0, 10) : 'N/A'
        else
          .w3-panel.w3-pale-yellow.w3-border
            p ℹ️ Nenhum recurso encontrado. Tenta outra pesquisa ou faz upload de um novo ficheiro!
            
    if user && user.nivel !== 'consumidor'
      .w3-container.w3-margin-top.w3-center
        a.w3-button.w3-teal.w3-round-large(href="/upload") 📤 Submeter Novo Recurso